---
import Card from './Card.astro';
import data from '../data/data.json';
const { projects } = data;

// Build triangle rows: 2, 3, 4, 5, 5, 5...
// If leftover can't fill the next row, append to current row
const rows: typeof projects[] = [];
let i = 0;
let rowSize = 2;
while (i < projects.length) {
	const remaining = projects.length - i - rowSize;
	if (remaining === 1) {
		rows.push(projects.slice(i, i + rowSize + 1));
		i += rowSize + 1;
	} else {
		rows.push(projects.slice(i, i + rowSize));
		i += rowSize;
	}
	rowSize = Math.min(rowSize + 1, 5);
}
---

<section id="projects">
	<h2>projects</h2>
	<div class="projects-triangle">
		{rows.map((row) => (
			<div class="projects-row" style={`grid-template-columns: repeat(${row.length}, 220px);`}>
				{row.map((project) => (
					<Card
						href={project.url}
						image={project.image}
						title={project.name}
						description={project.description}
						tech={project.tech}
						external={true}
					/>
				))}
			</div>
		))}
	</div>
	<div class="projects-mobile-grid">
		{projects.map((project) => (
			<Card
				href={project.url}
				image={project.image}
				title={project.name}
				description={project.description}
				tech={project.tech}
				external={true}
			/>
		))}
	</div>
</section>

<style>
	#projects {
		margin-bottom: 60px;
	}

	.projects-row {
		display: grid;
		gap: 20px;
		margin-bottom: 20px;
	}

	.projects-mobile-grid {
		display: none;
	}

	@media screen and (max-width: 600px) {
		.projects-triangle {
			display: none;
		}

		.projects-mobile-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 20px;
		}
	}
</style>
